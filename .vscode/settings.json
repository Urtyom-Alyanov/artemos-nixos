{
  "nix.enableLanguageServer": true,
  "nix.formatterPath": "alejandra",
  
  "nix.serverPath": "nixd",

  "nix.serverSettings": {
    "nixd": {
      "nixpkgs": {
        "expr": "let flake = builtins.getFlake \"${workspaceFolder}\"; in import flake.inputs.nixpkgs { system = \"${builtins.currentSystem}\"; overlays = (flake.internal.allOverlays or []); }"
      },
      "formatting": {
        "command": [ "alejandra" ]
      },
      "flakes": {
        "expr": "builtins.getFlake \"${workspaceFolder}\""
      },
      "options": {
        "nixos": {
          "expr": "(builtins.getFlake \"${workspaceFolder}\").nixosConfigurations.SHIZZA.options"
        },
        "flake-parts": {
          "expr": "(builtins.getFlake \"${workspaceFolder}\").debug.options" 
        },
        "home-manager": {
          "expr": "(builtins.getFlake \"${workspaceFolder}\").nixosConfigurations.SHIZZA.options.home-manager"
        },
        "home-manager-standalone": {
          "expr": "(builtins.getFlake \"${workspaceFolder}\").homeConfigurations.artemos.options"
        }
      }
    }
  },
  "[nix]": {
    // "editor.defaultFormatter": "jnoortheen.nix-ide",
    "editor.formatOnSave": true
  },

  "nixEnvSelector.useFlakes": true,
  "nixEnvSelector.nixFile": "${workspaceFolder}/flake.nix",
  "nixEnvSelector.flakeShell": "default"
}
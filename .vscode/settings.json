{
  "nix.enableLanguageServer": true,
  "nix.formatterPath": "alejandra",
  
  "nix.serverPath": "nixd",
  "nixEnvSelector.useFlakes": true,

  "nix.serverSettings": {
    "nixd": {
      "nixpkgs": {
        "expr": "import (builtins.getFlake \"${workspaceRoot}\").inputs.nixpkgs { }"
      },
      "formatting": {
        "command": [ "nixfmt" ]
      },
      "flakes": {
        "expr": "builtins.getFlake \"${workspaceRoot}\""
      },
      "options": {
        "nixos": {
          "expr": "(builtins.getFlake \"${workspaceRoot}\").nixosConfigurations.SHIZZA.options"
        },
        "flake-parts": {
          "expr": "(builtins.getFlake \"${workspaceRoot}\").debug.options"
        },
        "home-manager": {
          "expr": "(builtins.getFlake \"${workspaceRoot}\").inputs.home-manager.nixosModules.home-manager.options"
        }
      }
    }
  },
  "[nix]": {
    "editor.defaultFormatter": "jnahmias.nix-ide",
    "editor.formatOnSave": true
  }
}